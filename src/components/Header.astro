---
import { siteContent } from '../data/site';

const navItems = siteContent.navigation;
---

<header class="site-header">
  <nav class="site-header__nav" aria-label="Primary navigation">
    <div class="site-header__inner container">
      <div class="site-header__left">
        <a class="site-header__brand" href="#home" aria-label={`${siteContent.company.name} home`}>
          <img
            class="site-header__logo"
            src={siteContent.company.logo.src}
            alt={siteContent.company.logo.alt}
            loading="eager"
            decoding="async"
          />
        </a>
        <a
          aria-label={`${siteContent.company.name} on Facebook`}
          class="site-header__social"
          href={siteContent.socials.facebook}
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="#1877f2"
              d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
            />
          </svg>
        </a>
        <a
          aria-label={`${siteContent.company.name} on Instagram`}
          class="site-header__social"
          href={siteContent.socials.instagram}
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <defs>
              <radialGradient id="ig-grad-header" cx="30%" cy="107%" r="150%">
                <stop offset="0%" stop-color="#fdf497" />
                <stop offset="5%" stop-color="#fdf497" />
                <stop offset="45%" stop-color="#fd5949" />
                <stop offset="60%" stop-color="#d6249f" />
                <stop offset="90%" stop-color="#285aeb" />
              </radialGradient>
            </defs>
            <path
              fill="url(#ig-grad-header)"
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.981 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
            />
          </svg>
        </a>
      </div>

      <button
        class="site-header__toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-toggle
      >
        <span class="material-symbols-outlined" aria-hidden="true">menu</span>
        <span class="sr-only">Toggle navigation</span>
      </button>

      <div class="site-header__desktop">
        {
          navItems.map((item, index) => (
            <a
              class:list={['site-header__link', index === 0 && 'site-header__link--active']}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
        <a class="button button--primary button--small" href="#contact">Free Quote</a>
      </div>
    </div>
  </nav>

  <div class="site-header__mobile" id="mobile-navigation" data-menu-panel hidden>
    <div class="site-header__mobile-inner container">
      {
        navItems.map((item) => (
          <a class="site-header__mobile-link" href={item.href} data-menu-link>
            {item.label}
          </a>
        ))
      }
      <a class="button button--primary" href="#contact" data-menu-link>Free Quote</a>
    </div>
  </div>
</header>

<script is:inline>
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const menuPanel = document.querySelector('[data-menu-panel]');
  const menuLinks = document.querySelectorAll('[data-menu-link]');

  if (menuToggle instanceof HTMLButtonElement && menuPanel instanceof HTMLElement) {
    const closeMenu = () => {
      menuToggle.setAttribute('aria-expanded', 'false');
      menuPanel.hidden = true;
      document.body.classList.remove('menu-open');
    };

    menuToggle.addEventListener('click', () => {
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
      menuPanel.hidden = isOpen;
      document.body.classList.toggle('menu-open', !isOpen);
    });

    menuLinks.forEach((link) => link.addEventListener('click', closeMenu));
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 960) {
        closeMenu();
      }
    });
  }
</script>
