---
import { siteContent } from '../data/site';
---

<section class="hero" id="home">
  <div class="hero__media">
    <img
      src={siteContent.hero.image}
      alt={siteContent.hero.alt}
      class="hero__image"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>

  <h1 class="sr-only">Precision in Every Surface.</h1>
</section>
