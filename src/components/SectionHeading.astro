---
type Props = {
  eyebrow: string;
  title: string;
  body?: string;
  centered?: boolean;
};

const { eyebrow, title, body, centered = false } = Astro.props;
---

<div class:list={['section-heading', centered && 'section-heading--centered']}>
  <span class="section-heading__eyebrow">{eyebrow}</span>
  <h2 class="section-heading__title">{title}</h2>
  {body && <p class="section-heading__body">{body}</p>}
</div>
