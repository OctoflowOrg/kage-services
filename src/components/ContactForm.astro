---
import { siteContent } from '../data/site';
---

<form
  class="contact-form"
  method="POST"
  action={siteContent.contact.formspreeEndpoint}
  accept-charset="UTF-8"
  data-contact-form
>
  <input type="hidden" name="_subject" value="New KAGE Services website enquiry" />
  <div class="contact-form__honeypot" aria-hidden="true">
    <label for="company">Company</label>
    <input id="company" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <div class="contact-form__grid">
    <div class="field">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" placeholder="John Doe" autocomplete="name" required />
    </div>

    <div class="field">
      <label for="email">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder="john@example.com"
        autocomplete="email"
        required
      />
    </div>
  </div>

  <div class="field">
    <label for="serviceType">Service Type</label>
    <select id="serviceType" name="serviceType" required>
      <option value="">Select a service</option>
      {siteContent.contact.serviceOptions.map((option) => (
        <option value={option}>{option}</option>
      ))}
    </select>
  </div>

  <div class="field">
    <label for="message">Message</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      placeholder="Tell us about your project..."
      required
    ></textarea>
  </div>

  <button class="button button--primary button--full-width" type="submit" data-submit-button>
    Send Request
  </button>

  <p class="form-status" data-form-status role="status" aria-live="polite"></p>
</form>

<script is:inline>
  const contactForm = document.querySelector('[data-contact-form]');
  const submitButton = document.querySelector('[data-submit-button]');
  const statusElement = document.querySelector('[data-form-status]');

  if (
    contactForm instanceof HTMLFormElement &&
    submitButton instanceof HTMLButtonElement &&
    statusElement instanceof HTMLParagraphElement
  ) {
    contactForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(contactForm);
      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      statusElement.className = 'form-status';
      statusElement.textContent = '';

      try {
        const response = await fetch(contactForm.action, {
          method: contactForm.method,
          body: formData,
          headers: {
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error('Unable to send your request right now.');
        }

        contactForm.reset();
        statusElement.classList.add('form-status--success');
        statusElement.textContent = 'Thanks, your request has been sent. We will be in touch soon.';
      } catch (error) {
        console.error(error);
        statusElement.classList.add('form-status--error');
        statusElement.textContent =
          'Something went wrong while sending your request. Please try again or call us directly.';
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Send Request';
      }
    });
  }
</script>
